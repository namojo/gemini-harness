# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
MANIFEST

# Distribution / packaging
build/
dist/
wheels/
*.whl
*.tar.gz

# Virtual environments
.venv/
venv/
env/

# Testing / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
coverage.xml
htmlcov/


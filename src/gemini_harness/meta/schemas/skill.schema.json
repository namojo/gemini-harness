{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gemini-harness.local/schema/skill.schema.json",
  "title": "GeminiHarnessSkillFrontmatter",
  "description": "SKILL.md의 YAML frontmatter 스키마. runtime=python|bash만 허용. entry 필드는 실파일 존재 검증이 필요하므로 linter에서 별도 체크(sk.entry_file_exists). description의 pushy 품질은 정성 평가이므로 린터는 길이·금지어만 검증.",
  "type": "object",
  "required": ["name", "version", "description", "runtime", "entry"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "minLength": 2,
      "maxLength": 64,
      "description": "스킬 slug. .agents/skills/{name}/ 디렉토리명과 일치해야 한다."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
      "description": "semver. 초기 생성물은 '1.0'."
    },
    "description": {
      "type": "string",
      "minLength": 50,
      "maxLength": 500,
      "description": "pushy 트리거 설명. 50~500자. 스킬이 하는 일 + 구체적 트리거 상황을 모두 기술."
    },
    "runtime": {
      "enum": ["python", "bash"],
      "description": "entry 실행 런타임. 확장은 v2에서 검토."
    },
    "entry": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_./-]+\\.(py|sh)$",
      "description": ".agents/skills/{name}/ 기준 상대경로. 실파일 존재 여부는 린터가 검증."
    },
    "inputs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "entry 스크립트 입력 설명 (선택).",
      "default": []
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "entry 스크립트 출력 설명 (선택).",
      "default": []
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string"
    }
  }
}
